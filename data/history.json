      "severity": "moderate",
      "confidence": 0.92,
      "symptoms": [
        "叶片上出现不规则形的褐色或灰黑色病斑，病斑边缘清晰，后期病斑中央易穿孔破裂",
        "病斑周围可能出现黄色晕圈，严重时多个病斑融合导致叶片大面积枯死",
        "病害初期病斑较小，随着病情发展逐渐扩大，影响叶片光合作用"
      ],
      "treatments": [
        {
          "title": "化学防治",
          "detail": "发病初期及时喷洒70%代森锰锌可湿性粉剂600倍液，或50%多菌灵可湿性粉剂800倍液，每隔7-10天喷一次，连续2-3次。注意交替使用不同作用机制的杀菌剂以避免抗药性产生。"
        },
        {
          "title": "物理防治",
          "detail": "及时摘除并销毁病叶，减少病原菌的传播源。保持植株通风透光，避免过度密植，降低湿度有助于抑制病害发展。"
        },
        {
          "title": "加强管理",
          "detail": "合理施肥，增施磷钾肥以增强植株抗病能力；浇水时避免叶片积水，最好在早晨进行，确保叶片快速干燥。"
        }
      ],
      "prevention": [
        "选择抗病品种种植，从源头减少病害发生几率。",
        "定期清理园内落叶和病残体，集中烧毁或深埋，消除越冬病原。",
        "加强栽培管理，合理密植，保证植株间空气流通，降低湿度。",
        "发病季节前，提前喷施保护性杀菌剂（如代森锰锌）进行预防，每10-14天一次，连续2-3次。"
      ]
    }
